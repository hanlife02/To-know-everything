# Minimal setup
# PKU source will auto-enable when username/password are present.
PKU_REAGENT_USERNAME=
PKU_REAGENT_PASSWORD=

# Optional notification channels
# Telegram will auto-enable when token/chat_id are present.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Bark will auto-enable when key is present.
# BARK_KEY=
# BARK_GROUP=

# Optional overrides
# APP_ENV=development
# APP_LOG_LEVEL=INFO
# APP_DATA_DIR=data
# TELEGRAM_ENABLED=true
# TELEGRAM_DISABLE_WEB_PAGE_PREVIEW=true
# BARK_ENABLED=true
# BARK_SERVER_URL=https://api.day.app
# AUTOMATION_ENABLED=false
# AUTOMATION_DAILY_TIME=09:00
# AUTOMATION_DEFAULT_MODE=summary
# WEB_API_KEY=
# ENABLED_SOURCES=
# PKU_REAGENT_ENABLED=true
# PKU_REAGENT_BASE_URL=https://reagent.pku.edu.cn
# PKU_REAGENT_IAAA_BASE_URL=https://iaaa.pku.edu.cn/iaaa
# PKU_REAGENT_TOKEN=
# PKU_REAGENT_COOKIE=
# PKU_REAGENT_CAPTCHA_CODE=
# PKU_REAGENT_SMS_CODE=
# PKU_REAGENT_OTP_CODE=
# PKU_REAGENT_START_DATE=
# PKU_REAGENT_END_DATE=
# PKU_REAGENT_KEYWORD=
# PKU_REAGENT_GROUP_CODE=
# PKU_REAGENT_PAGE_SIZE=20
